# Django

SECRET_KEY=ключ для приложения django
DEBUG=статус режима отладки True / False

# DB postgresql

POSTGRES_DB=имя базы данных
POSTGRES_USER=имя пользователя базы данных
POSTGRES_PASSWORD=пароль пользователя базы данных
POSTGRES_HOST=адрес хоста базы данных
POSTGRES_PORT=порт базы данных

# Celery

CELERY_BROKER_URL=адрес брокера для отправки задач
CELERY_RESULT_BACKEND=адрес брокера для хранения задач

# Telegram

TELEGRAM_API_BOT=токен для бота в телеграмме
TELEGRAM_API_URL=url для запросов api - https://api.telegram.org/bot